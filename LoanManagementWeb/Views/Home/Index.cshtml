@{
    ViewData["Title"] = "Dashboard";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h4 class="fw-bold mb-0"><i class="bi bi-speedometer2 me-2 text-primary"></i>Dashboard</h4>
        <small class="text-muted">Welcome back, <strong>@Context.Session.GetString("Username")</strong> 
        &nbsp;|&nbsp; Role: <span class="badge bg-primary">@Context.Session.GetString("Role")</span></small>
    </div>
    <small class="text-muted">@DateTime.Now.ToString("dddd, MMMM dd, yyyy")</small>
</div>

<!-- Stats row -->
<div class="row g-3 mb-4">
    <div class="col-sm-6 col-lg-3">
        <div class="stat-card card border-0 shadow-sm h-100">
            <div class="card-body d-flex align-items-center gap-3">
                <div class="stat-icon bg-primary bg-opacity-10 text-primary">
                    <i class="bi bi-people-fill fs-3"></i>
                </div>
                <div>
                    <div class="stat-value">@ViewBag.TotalCustomers</div>
                    <div class="stat-label">Total Customers</div>
                </div>
            </div>
        </div>
    </div>
    <div class="col-sm-6 col-lg-3">
        <div class="stat-card card border-0 shadow-sm h-100">
            <div class="card-body d-flex align-items-center gap-3">
                <div class="stat-icon bg-success bg-opacity-10 text-success">
                    <i class="bi bi-cash-coin fs-3"></i>
                </div>
                <div>
                    <div class="stat-value">@ViewBag.ActiveLoans</div>
                    <div class="stat-label">Active Loans</div>
                </div>
            </div>
        </div>
    </div>
    <div class="col-sm-6 col-lg-3">
        <div class="stat-card card border-0 shadow-sm h-100">
            <div class="card-body d-flex align-items-center gap-3">
                <div class="stat-icon bg-warning bg-opacity-10 text-warning">
                    <i class="bi bi-currency-dollar fs-3"></i>
                </div>
                <div>
                    <div class="stat-value">@($"{(decimal)ViewBag.TotalDisbursed:C0}")</div>
                    <div class="stat-label">Total Disbursed</div>
                </div>
            </div>
        </div>
    </div>
    <div class="col-sm-6 col-lg-3">
        <div class="stat-card card border-0 shadow-sm h-100">
            <div class="card-body d-flex align-items-center gap-3">
                <div class="stat-icon bg-info bg-opacity-10 text-info">
                    <i class="bi bi-credit-card-fill fs-3"></i>
                </div>
                <div>
                    <div class="stat-value">@($"{(decimal)ViewBag.TotalCollected:C0}")</div>
                    <div class="stat-label">Total Collected</div>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Quick links -->
<div class="row g-3">
    <div class="col-md-4">
        <div class="card border-0 shadow-sm">
            <div class="card-body text-center py-4">
                <i class="bi bi-person-plus-fill text-primary fs-1 mb-2 d-block"></i>
                <h6 class="fw-bold">Add Customer</h6>
                <p class="text-muted small">Register a new loan customer</p>
                <a href="/Customer/Create" class="btn btn-primary btn-sm px-4">Go</a>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card border-0 shadow-sm">
            <div class="card-body text-center py-4">
                <i class="bi bi-file-earmark-plus-fill text-success fs-1 mb-2 d-block"></i>
                <h6 class="fw-bold">New Loan</h6>
                <p class="text-muted small">Create a new loan application</p>
                <a href="/Loan/Create" class="btn btn-success btn-sm px-4">Go</a>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card border-0 shadow-sm">
            <div class="card-body text-center py-4">
                <i class="bi bi-cash-stack text-warning fs-1 mb-2 d-block"></i>
                <h6 class="fw-bold">Record Payment</h6>
                <p class="text-muted small">Log a loan repayment</p>
                <a href="/Payment/Create" class="btn btn-warning btn-sm px-4">Go</a>
            </div>
        </div>
    </div>
</div>
