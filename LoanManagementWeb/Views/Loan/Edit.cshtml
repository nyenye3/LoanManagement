@model Loan
@{
    ViewData["Title"] = "Edit Loan";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h4 class="fw-bold mb-0"><i class="bi bi-pencil-square me-2 text-success"></i>Edit Loan #@Model.LoanID</h4>
    <a href="/Loan" class="btn btn-outline-secondary btn-sm">
        <i class="bi bi-arrow-left me-1"></i>Back to List
    </a>
</div>

<div class="card border-0 shadow-sm">
    <div class="card-body p-4">
        <form asp-action="Edit" method="post">
            @Html.AntiForgeryToken()
            <input asp-for="LoanID"           type="hidden" />
            <input asp-for="RemainingBalance" type="hidden" />
            <div asp-validation-summary="ModelOnly" class="alert alert-danger py-2 small"></div>

            <div class="row">
                <div class="col-md-6 mb-3">
                    <label asp-for="CustomerID" class="form-label fw-semibold"></label>
                    <select asp-for="CustomerID" asp-items="ViewBag.Customers" class="form-select">
                        <option value="">-- Select Customer --</option>
                    </select>
                    <span asp-validation-for="CustomerID" class="text-danger small"></span>
                </div>
                <div class="col-md-6 mb-3">
                    <label asp-for="Status" class="form-label fw-semibold"></label>
                    <select asp-for="Status" class="form-select">
                        <option value="">-- Select Status --</option>
                        <option value="Pending">Pending</option>
                        <option value="Active">Active</option>
                        <option value="Paid">Paid</option>
                        <option value="Defaulted">Defaulted</option>
                    </select>
                    <span asp-validation-for="Status" class="text-danger small"></span>
                </div>
            </div>

            <div class="row">
                <div class="col-md-4 mb-3">
                    <label asp-for="LoanAmount" class="form-label fw-semibold"></label>
                    <div class="input-group">
                        <span class="input-group-text">$</span>
                        <input asp-for="LoanAmount" class="form-control" step="0.01" />
                    </div>
                    <span asp-validation-for="LoanAmount" class="text-danger small"></span>
                </div>
                <div class="col-md-4 mb-3">
                    <label asp-for="InterestRate" class="form-label fw-semibold"></label>
                    <div class="input-group">
                        <input asp-for="InterestRate" class="form-control" step="0.01" />
                        <span class="input-group-text">%</span>
                    </div>
                    <span asp-validation-for="InterestRate" class="text-danger small"></span>
                </div>
                <div class="col-md-4 mb-3">
                    <label asp-for="LoanTermMonths" class="form-label fw-semibold"></label>
                    <div class="input-group">
                        <input asp-for="LoanTermMonths" class="form-control" />
                        <span class="input-group-text">months</span>
                    </div>
                    <span asp-validation-for="LoanTermMonths" class="text-danger small"></span>
                </div>
            </div>

            <div class="col-md-4 mb-3">
                <label asp-for="ApplicationDate" class="form-label fw-semibold"></label>
                <input asp-for="ApplicationDate" type="date" class="form-control"
                       max="@DateTime.Today.ToString("yyyy-MM-dd")" />
                <span asp-validation-for="ApplicationDate" class="text-danger small"></span>
            </div>

            <hr />
            <div class="d-flex gap-2">
                <button type="submit" class="btn btn-primary px-4">
                    <i class="bi bi-save me-1"></i>Update Loan
                </button>
                <a href="/Loan" class="btn btn-outline-secondary px-4">Cancel</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/jquery-validation@1.19.5/dist/jquery.validate.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/jquery-validation-unobtrusive@3.2.12/dist/jquery.validate.unobtrusive.min.js"></script>
}
